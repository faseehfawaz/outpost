# ==============================================================================
# Outpost Intelligence Pipeline — Production Environment Configuration (.env)
# Deployment Target: HP EliteDesk 800 G4 Mini (/opt/heapleap/.env)
# ==============================================================================

# ---- Environment & Logging ----
PKINTEL_ENV=prod
PKINTEL_LOG_LEVEL=INFO
PKINTEL_LOG_JSON=true

# ---- Observability (Sentry & Datadog) ----
# Sentry DSN for crash reports and exception tracking
PKINTEL_SENTRY_DSN=
PKINTEL_SENTRY_TRACES_SAMPLE_RATE=0.3

# Datadog service identification
PKINTEL_DD_SERVICE=outpost
PKINTEL_DD_ENV=prod

# ---- Database (Local PostgreSQL on EliteDesk) ----
PKINTEL_DB_URL=postgresql://outpost:outpost@localhost:5432/outpost
PKINTEL_DB_POOL_MIN=2
PKINTEL_DB_POOL_MAX=20

# ---- Object Storage (Cloudflare R2 for Quarantined Kit Archives) ----
# Cloudflare R2 speaks standard S3 API. If left empty, local storage is used.
PKINTEL_R2_ENDPOINT=
PKINTEL_R2_BUCKET=pkintel-kits
PKINTEL_R2_ACCESS_KEY_ID=
PKINTEL_R2_SECRET_ACCESS_KEY=
# Local storage fallback directory on EliteDesk
PKINTEL_LOCAL_STORAGE_DIR=/opt/heapleap/.storage/kits

# ---- HTTP Client & Ethics Limits ----
PKINTEL_USER_AGENT="pkintel-research/0.1 (+https://heapleap.tech; passive phishing-kit research; contact security@heapleap.tech)"
PKINTEL_PER_HOST_MIN_INTERVAL_S=3.0
PKINTEL_KITHUNT_REQUEST_INTERVAL_S=4.0
PKINTEL_KITHUNT_MAX_ATTEMPTS_PER_HOST=12

# ---- Analyzer Sandbox (Docker Container Limits) ----
PKINTEL_ANALYZER_IMAGE=pkintel-analyzer:latest
PKINTEL_ANALYZER_TIMEOUT_S=120
PKINTEL_ANALYZER_MEM_LIMIT=512m
PKINTEL_ANALYZER_CPU_LIMIT=1.0

# ---- Intelligence Feeds & Certificate Transparency ----
PKINTEL_URLHAUS_ENABLED=true
PKINTEL_OPENPHISH_ENABLED=true
PKINTEL_URLSCAN_API_KEY=
PKINTEL_CT_ENABLED=true
PKINTEL_CERTSTREAM_URL=wss://certstream.calidog.io/

# ---- Automated Takedowns & Notifications ----
# Set PKINTEL_TAKEDOWN_DRY_RUN=false ONLY when ready to issue live abuse emails
PKINTEL_TAKEDOWN_DRY_RUN=true
PKINTEL_TAKEDOWN_FROM_EMAIL=security@heapleap.tech
PKINTEL_TAKEDOWN_OVERRIDE_RECIPIENT=

# SMTP Configuration for outbound abuse notifications
PKINTEL_SMTP_HOST=smtp.gmail.com
PKINTEL_SMTP_PORT=587
PKINTEL_SMTP_USER=security@heapleap.tech
PKINTEL_SMTP_PASS=
PKINTEL_SMTP_USE_TLS=true

# Google Safe Browsing API Key
PKINTEL_GSB_API_KEY=
