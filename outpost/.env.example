# Copy to .env and fill in. Everything has a safe dev default; you can run the
# whole pipeline locally with only PKINTEL_DB_URL set.

# ---- core ----
PKINTEL_ENV=dev
PKINTEL_LOG_LEVEL=INFO
PKINTEL_LOG_JSON=false

# ---- database ----
PKINTEL_DB_URL=postgresql://pkintel:pkintel@localhost:5432/pkintel

# ---- object storage (Cloudflare R2). Leave blank to use local ./.storage ----
PKINTEL_R2_ENDPOINT=
PKINTEL_R2_BUCKET=pkintel-kits
PKINTEL_R2_ACCESS_KEY_ID=
PKINTEL_R2_SECRET_ACCESS_KEY=
PKINTEL_LOCAL_STORAGE_DIR=./.storage/kits

# ---- HTTP politeness (ethics-critical; raise, don't lower) ----
PKINTEL_PER_HOST_MIN_INTERVAL_S=3.0
PKINTEL_KITHUNT_REQUEST_INTERVAL_S=4.0
PKINTEL_KITHUNT_MAX_ATTEMPTS_PER_HOST=12

# ---- analyzer ----
PKINTEL_ANALYZER_IMAGE=pkintel-analyzer:latest
PKINTEL_ANALYZER_TIMEOUT_S=120

# ---- feeds (all optional) ----
PKINTEL_URLHAUS_ENABLED=true
PKINTEL_OPENPHISH_ENABLED=true
PKINTEL_URLSCAN_API_KEY=
PKINTEL_CT_ENABLED=true
PKINTEL_CERTSTREAM_URL=wss://certstream.calidog.io/

# ---- takedown ----
PKINTEL_TAKEDOWN_DRY_RUN=true
PKINTEL_TAKEDOWN_FROM_EMAIL=abuse-reports@yourdomain
PKINTEL_GSB_API_KEY=
